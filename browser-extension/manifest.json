{
  "manifest_version": 3,
  "name": "Adult Content Shutdown Guard",
  "short_name": "ACSG Guard",
  "version": "1.0.2",
  "description": "Connects managed browsers to the local AdultContentShutdownGuard Windows service for domain and page-risk enforcement.",
  "permissions": ["tabs", "webNavigation", "storage"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:8765/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "storage": {
    "managed_schema": "schema.json"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["rules.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Adult Content Shutdown Guard",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "popup.html"
  }
}
