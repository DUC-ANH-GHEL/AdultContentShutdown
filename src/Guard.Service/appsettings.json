{
  "Guard": {
    "Port": 8765,
    "Token": "CHANGE_THIS_SECRET_TOKEN",
    "LegacyExtensionEndpointEnabled": false,
    "DryRun": false,
    "ShutdownCommand": "shutdown.exe",
    "ShutdownArguments": "/s /t 0 /f /c \"Adult content blocked by AdultContentShutdownGuard\"",
    "LogDirectory": "C:\\ProgramData\\AdultContentShutdownGuard\\Logs",
    "DebounceSeconds": 3,
    "EnableDomainRules": true,
    "EnableKeywordRules": true,
    "MinScoreToShutdown": 100,
    "Dns": {
      "Enabled": false,
      "ListenAddress": "127.0.0.1",
      "ListenPort": 53,
      "UpstreamServers": [ "1.1.1.1", "8.8.8.8" ],
      "UpstreamTimeoutMilliseconds": 2500,
      "ReturnNxDomain": false,
      "SinkholeAddress": "0.0.0.0"
    },
    "Enforcement": {
      "ActionOnViolation": "LogOnly",
      "ActionOnTamper": "Shutdown",
      "ApplyOnStartup": false,
      "ConfigureDnsAdapters": false,
      "ConfigureFirewallRules": false
    },
    "BrowserPolicies": {
      "Enabled": false,
      "DisableDnsOverHttps": true,
      "DisableQuic": true,
      "LockProxySettings": false
    },
    "Tamper": {
      "Enabled": true,
      "CheckIntervalSeconds": 30,
      "RestoreSettings": false
    },
    "ProcessRules": {
      "Enabled": true,
      "CheckIntervalSeconds": 10,
      "ActionOnWorkVpnDetected": "LogOnly",
      "AllowedWorkVpnProcesses": [
        "openvpn",
        "protonvpn",
        "nordvpn",
        "expressvpn",
        "windscribe",
        "cloudflare-warp",
        "warp-svc"
      ],
      "BlockedProcessNames": [
        "tor",
        "torbrowser",
        "psiphon",
        "ultrasurf"
      ]
    },
    "BlocklistUpdates": {
      "Enabled": true,
      "RemoteUrl": "",
      "Sha256": "",
      "RefreshIntervalMinutes": 1440,
      "CacheFilePath": "C:\\ProgramData\\AdultContentShutdownGuard\\Config\\adult-domains.remote.txt"
    },
    "PassiveDnsMonitor": {
      "Enabled": true,
      "EventLogName": "Microsoft-Windows-DNS-Client/Operational",
      "PollIntervalSeconds": 5,
      "LookbackMinutesOnStartup": 2
    },
    "NetworkPosture": {
      "Enabled": true,
      "CheckIntervalSeconds": 60,
      "ActionOnUnsafePosture": "LogOnly"
    },
    "ManagedBrowserEndpoint": {
      "Enabled": false,
      "ChromeExtensionId": "",
      "EdgeExtensionId": "",
      "UpdateUrl": "",
      "UpdateManifestPath": "",
      "CrxPath": ""
    }
  }
}
